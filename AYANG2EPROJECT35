#include <stdio.h>

int main()
{
    int n, i;
    float sum = 0.0;

    printf("Enter the number of terms (n): ");
    scanf("%d", &n);

    for(i = 1; i <= n; i++)
    {
        sum = sum + 1.0 / i;
    }

    printf("Sum of the series 1 + 1/2 + 1/3 + ... + 1/%d = %.6f\n", n, sum);

    return 0;
}
