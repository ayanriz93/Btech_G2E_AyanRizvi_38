#include <stdio.h>

int main() {
    int n, i;
    int even_count = 0, odd_count = 0;

    printf("Enter the size of the array: ");
    scanf("%d", &n);

    int arr[n];
    printf("Enter %d elements: ", n);
    for(i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Counting logic
    for(i = 0; i < n; i++) {
        if(arr[i] % 2 == 0) {
            even_count++;
        } else {
            odd_count++;
        }
    }

    printf("Even Numbers: %d\n", even_count);
    printf("Odd Numbers: %d\n", odd_count);

    return 0;
}
