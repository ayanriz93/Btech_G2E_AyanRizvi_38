#include <stdio.h>

int main() {
    int array[100], search, i, n;

    printf("Enter number of elements in array: ");
    scanf("%d", &n);

    printf("Enter %d integers:\n", n);
    for (i = 0; i < n; i++) {
        scanf("%d", &array[i]);
    }

    printf("Enter a number to search: ");
    scanf("%d", &search);

    // Linear Search Logic
    for (i = 0; i < n; i++) {
        if (array[i] == search) {
            printf("%d is present at location %d (Index %d).\n", search, i + 1, i);
            break; // Exit loop as soon as the element is found
        }
    }

    if (i == n) {
        printf("%d is not present in the array.\n", search);
    }

    return 0;
}
